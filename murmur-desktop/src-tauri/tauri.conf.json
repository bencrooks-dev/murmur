{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Murmur",
  "version": "0.1.0",
  "identifier": "dev.bencrooks.murmur",
  "build": {
    "frontendDist": "../../murmur-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../murmur-web run dev",
    "beforeBuildCommand": "npm --prefix ../murmur-web install && npm --prefix ../murmur-web run build"
  },
  "app": {
    "windows": [
      {
        "title": "Murmur",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
